#!/usr/bin/env bash

BEM_VERSION='0.1.0'
BEM_HOME="$HOME/.bem"
BEM_LINKS="$BEM_HOME/bin"
BEM_SOURCES="$BEM_HOME/source"
NAME_MAX=64
NAME_RE='^[a-zA-Z0-9_][a-zA-Z0-9._-]*$'

umask 077

usage() {
    cat <<EOF
usage: bem [-v | --version] [-h | --help] <command> [<args>]

These are all available bem commands:

setup
init           Initialize bem in $BEM_HOME
uninstall-bem Remove $BEM_HOME completely

programs
install        Install executable files as commands
remove         Remove installed command links
rm             Alias for remove

shell source files
source         Install shell files to be sourced at shell startup
desource       Remove installed source links

inspection
list           List installed commands and source files
ls             Alias for list
status         Show whether names are installed as commands or source files

information
version        Print the bem version
help           Show this help message

Command usage:

bem init
bem install [-n | --name <name>] <file> ...
bem remove <name> ...
bem source [-n | --name <name>] <file> ...
bem desource <name> ...
bem list
bem status <name> ...
bem uninstall-bem
bem version
bem help

Names:

names must match:    $NAME_RE
maximum name length: $NAME_MAX

Shell setup:

Run:

  bem init

Then add this line to your shell startup file:

  source $BEM_HOME/bem.source

Environment:

BEM_ALLOW_ROOT=1
Allow running bem as root. Root is refused by default.

Exit codes:

0    success
64   usage error
65   invalid name or invalid input data
66   missing input, wrong input type, or installed name not found
69   conflict, missing installation, or corrupted installation
70   internal software error
73   cannot create file, directory, or symlink
74   I/O error
75   temporary failure
126  permission denied, unsafe owner, unsafe mode, or refused root execution
EOF
}

die() {
    local exit_code=$1
    local format=$2
    shift 2
    printf "bem: $format\n" "$@" >&2
    exit "$exit_code"
}

uninstall_bem() {
    rm -rf -- "$BEM_HOME" || die 74 'cannot delete %q' "$BEM_HOME"
    echo "bem uninstalled"
    echo "remove these lines from your .bashrc file, if present:"
    printf '\tsource %q\n' "$BEM_HOME/bem.source"
}

clear_broken_install() {
    echo "bem: bem init failed. Cleaning up" >&2
    if [[ -e $BEM_HOME/bem.source ]]; then
        rm -f -- "$BEM_HOME/bem.source" || printf "cannot clear previous installation; remove manually sudo rm -- %q\n" "$BEM_HOME/bem.source" >&2
    fi
    local file
    for file in "$BEM_HOME"/bem.source.*; do
        if [[ -e "$file" ]]; then
            rm -f -- "$file"
        fi
    done
}

init() {
    local self bem_source bem_source_tmp
    [[ ( -e $BEM_HOME && ! -d $BEM_HOME ) || -L $BEM_HOME ]] && die 69 'conflict: %q exists and is not a regular directory' "$BEM_HOME"
    trap clear_broken_install EXIT
    [[ ( -e "$BEM_LINKS" && ! -d $BEM_LINKS ) || -L $BEM_LINKS ]] && die 69 'conflict: %q exists and is not a regular directory' "$BEM_LINKS"
    [[ ( -e "$BEM_SOURCES" && ! -d $BEM_SOURCES ) || -L $BEM_SOURCES ]] && die 69 'conflict: %q exists and is not a regular directory' "$BEM_SOURCES"
    mkdir -p -m 700 -- "$BEM_HOME" || die 73 'could not create %q' "$BEM_HOME"
    mkdir -p -m 700 -- "$BEM_LINKS" || die 73 'could not create %q' "$BEM_LINKS"
    mkdir -p -m 700 -- "$BEM_SOURCES" || die 73 'could not create %q' "$BEM_SOURCES"
    chmod 700 -- "$BEM_HOME" "$BEM_LINKS" "$BEM_SOURCES" || die 126 'could not secure bem directories'
    self=$(realpath -- "$0" ) || die 74 'could not resolve bem path'
    if [[ ! -L "$BEM_LINKS/bem" ]]; then
        [[ -e "$BEM_LINKS/bem" ]] && die 69 'conflict: delete %q/bem; corrupted installation' "$BEM_LINKS"
        ln -s -- "$self" "$BEM_LINKS/bem"  || die 73 'could not create %q/bem' "$BEM_LINKS"
    fi
    bem_source="$BEM_HOME/bem.source"
    if [[ -e $bem_source ]]; then
        rm -f -- "$bem_source" || die 69 "cannot clear previous installation try rerun 'bem init' or remove manually: sudo rm -- %q" "$bem_source"
    fi
    bem_source_tmp="$bem_source.$$"
    cat > "$bem_source_tmp" <<EOF
#!/usr/bin/env bash
#
# File generated by bem
#
#

_check_bem_integrity() {
    local home_stat 
    if ! home_stat=\$(stat -c '%f %u %a' -- "$BEM_HOME"); then
        echo "bem: cannot stat $BEM_HOME" >&2
        return 66
    fi
    if (( (16#\${home_stat%% *} & 0170000) != 0040000 )); then
        echo "bem: is not a directory $BEM_HOME" >&2
        return 69
    fi
    home_stat=\${home_stat#* }
    if (( \${home_stat%% *} != EUID )); then
        echo "bem: you don't own $BEM_HOME" >&2
        return 126
    fi
    if (( 8#\${home_stat#* } != 0700 )); then
        echo "bem: permission not safe $BEM_HOME" >&2
        return 126
    fi
}

if ! _check_bem_integrity &>/dev/null; then
    echo "bem: Error while checking bem integrity, run '_check_bem_integrity' for a full error message" >&2
    return
fi

export PATH="\$PATH:$BEM_LINKS"

_bem_source_files() {
    local file link_stat 
    for file in "$BEM_SOURCES"/*; do
        if [[ -L \$file ]]; then
            link_stat=\$(stat -Lc '%u %a' -- "\$file") || continue
            (( \${link_stat%% *} == EUID && 8#\${link_stat#* } == 0600 )) && source "\$file"
        fi
    done
}

_bem_autocomplete() {
	local cur prev cmd commands

	cur=\${COMP_WORDS[COMP_CWORD]}
	prev=\${COMP_WORDS[COMP_CWORD-1]}
	cmd=\${COMP_WORDS[1]}
	commands='init install source remove rm desource list ls status uninstall-bem version help'
	COMPREPLY=()

	if ((COMP_CWORD == 1)); then
		COMPREPLY=(\$(compgen -W "\$commands" -- "\$cur"))
		return
	fi

	case \$cmd in
		install|source)
			[[ \$prev == -n || \$prev == --name ]] && return

			if [[ \$cur == -* ]]; then
				COMPREPLY=(\$(compgen -W '-n --name' -- "\$cur"))
				return
			fi

			compopt -o default 2>/dev/null
			;;

		remove|rm)
			COMPREPLY=(\$(compgen -G "$BEM_LINKS/\$cur*"))
			COMPREPLY=(\${COMPREPLY[@]##*/})
			;;

		desource)
			COMPREPLY=(\$(compgen -G "$BEM_SOURCES/\$cur*"))
			COMPREPLY=(\${COMPREPLY[@]##*/})
			;;

		status)
			COMPREPLY=(\$(compgen -G "$BEM_LINKS/\$cur*") \$(compgen -G "$BEM_SOURCES/\$cur*"))
			COMPREPLY=(\${COMPREPLY[@]##*/})
			;;

		help)
			COMPREPLY=(\$(compgen -W "\$commands" -- "\$cur"))
			;;
	esac
}

complete -F _bem_autocomplete bem

_bem_source_files
EOF
    if (( $? != 0 )); then
        rm -f -- "$bem_source_tmp"
        die 73 'could not write %q' "$bem_source"
    fi
    chmod 400 -- "$bem_source_tmp" || die 126 'could not chmod %q' "$bem_source_tmp"
    mv -f -- "$bem_source_tmp" "$bem_source" || die 73 'could not create %q' "$bem_source"
    trap - EXIT
    printf 'bem initialized in %q\n' "$BEM_LINKS"
    echo 'add this line to your .bashrc:'
    printf '\tsource %q\n' "$bem_source"
}

check_installation() {
    local home_stat
    home_stat=$(stat -c '%f %u %a' -- "$BEM_HOME") || die 69 "bem is not initialized; run 'bem init'"
    (( (16#${home_stat%% *} & 0170000) == 0040000 )) || die 69 "bem is not initialized; run 'bem init'"
    home_stat=${home_stat#* }
    (( ${home_stat%% *} == EUID )) || die 126 "refusing unowned %q, fix with: 'chown -- %q'." "$BEM_HOME" "$BEM_HOME"
    (( 8#${home_stat#* } == 0700 )) || die 126 "refusing unsafe directory %q, fix with: 'chmod 700 -- %q'." "$BEM_HOME" "$BEM_HOME"
}


cmd_install() {
    (($# > 0)) || die 64 'usage: bem install [-n name] file ...'
    local name file path link file_stat 
    while (($# > 0)); do
        case $1 in
            -n|--name)
                (($# > 1)) || die 64 '-n requires a name'
                [[ -z $name ]] || die 64 "-n '%s' requires a file" "$name"
                name=$2
                shift 2
                ;;
            -*)
                die 64 "unknown option: %s" $1
                ;;
            *)
                file=$1
                shift
                file_stat=$(stat -c '%f %u %a' -- "$file") || die 66 'cannot stat %q' "$file"
                (( (16#${file_stat%% *} & 0170000) == 0100000 )) || die 66 'not a regular file: %q' "$file"
                file_stat=${file_stat#* }
                (( ${file_stat% *} == EUID )) || die 126 "refusing unowned %q, fix with: 'chown -- %q'" "$file" "$file"
                (( 8#${file_stat#* } == 0700 )) || die 126 "refusing untrusted file %q, fix with: 'chmod 700 -- %q'" "$file" "$file"
                path=$(realpath -- "$file") || die 74 'could not resolve %q' "$file"
                if [[ -z $name ]]; then
                    name=${path##*/}
                fi
                [[ $name =~ $NAME_RE ]] || die 65 'invalid name for program: %s' "$name"
                ((${#name} <= NAME_MAX)) || die 65 'name too long: %s' "$name"
                link="$BEM_LINKS/$name"
                [[ ! -e $link && ! -L $link ]] || die 69 'already exists: %q' "$link"
                type "$name" >/dev/null 2>&1 && die 69 'command already exists: %s' "$name"
                ln -s -- "$path" "$link" || die 73 'could not create %q' "$link"
                printf '%s -> %q\n' "$name" "$path"
                name=
                ;;
        esac
    done
    [[ -z $name ]] || die 64 '-n requires a file'
}

cmd_source() {
    local name file path link file_stat
    (($# > 0)) || die 64 'usage: bem source [-n name] file ...'
    while (($# > 0)); do
        case $1 in
            -n|--name)
                (($# > 1)) || die 64 '-n requires a name'
                [[ -z $name ]] || die 64 "-n '%s' requires a file" "$name"
                name=$2
                shift 2
                ;;
            -*)
                die 64 'unknown option: %s' $1
                ;;
            *)
                file=$1
                shift
                file_stat=$(stat -c '%f %u %a' -- "$file") || die 66 'cannot stat %q' "$file"
                (( (16#${file_stat%% *} & 0170000) == 0100000 )) || die 65 'not a regular file: %q' "$file"
                file_stat=${file_stat#* }
                (( ${file_stat% *} == EUID )) || die 126 "refusing unowned %q, fix with: 'chown -- %q'" "$file" "$file"
                (( 8#${file_stat#* } == 0600 )) || die 126 "refusing untrusted file %q, fix with: 'chmod 600 -- %q'" "$file" "$file"
                path=$(realpath -- "$file") || die 74 'could not resolve %q' "$file"
                if [[ -z $name ]]; then
                    name=${path##*/}
                fi
                [[ $name =~ $NAME_RE ]] || die 65 'invalid name for source file: %s' "$name"
                ((${#name} <= NAME_MAX)) || die 65 'name too long: %s' "$name"
                link="$BEM_SOURCES/$name"
                [[ ! -e $link && ! -L $link ]] || die 69 'already exists: %q' "$link"
                ln -s -- "$path" "$link" || die 73 'could not create %q' "$link"
                printf '%s -> %q\n' "$name" "$path"
                name=
                ;;
        esac
    done
    [[ -z $name ]] || die 64 '-n requires a file'
    echo "run 'exec bash' to apply the changes"
}

cmd_remove() {
    local name
    (($# > 0)) || die 64 'usage: bem remove name ...'
    for name in "$@"; do
        if [[ ! $name =~ $NAME_RE ]]; then
            die 65 'invalid name for program: %s' "$name"
        elif [[ ! -L "$BEM_LINKS/$name" ]]; then
            die 66 'not found: %s' "$name"
        fi
    done
    for name in "$@"; do
        rm -f -- "$BEM_LINKS/$name" || die 74 'could not remove %q' "$BEM_LINKS/$name"
        printf 'removed: %s\n' "$name"
    done
}

cmd_desource() {
    local name
    (($# > 0)) || die 64 'usage: bem desource name ...'
    for name in "$@"; do
        if [[ ! $name =~ $NAME_RE ]]; then
            die 65 'invalid name for source file: %s' "$name"
        elif [[ ! -L "$BEM_SOURCES/$name" ]]; then
            die 66 'not found: %s' "$name"
        fi
    done
    for name in "$@"; do
        rm -f -- "$BEM_SOURCES/$name" || die 74 'could not remove %q' "$BEM_SOURCES/$name"
        printf 'removed: %s\n' "$name"
    done
    echo "run 'exec bash' to apply the changes"
}

cmd_list() {
    local link code found
    found=0
    code=0
    echo 'Programs:'
    for link in "$BEM_LINKS"/*; do
        if [[ -L $link ]]; then
            if target=$(readlink -- "$link"); then
                printf '\t%s -> %q\n' "${link##*/}" "$target"
                found=1
            else
                printf 'bem: could not read %q\n' "$link" >&2
                code=74
            fi
        fi
    done
    ((found == 0)) && echo 'no program installed'
    found=0
    echo 'Source files:'
    for link in "$BEM_SOURCES"/*; do
        if [[ -L $link ]]; then
            if target=$(readlink -- "$link"); then
                printf '\t%s -> %q\n' "${link##*/}" "$target"
                found=1
            else
                printf 'bem: could not read %q\n' "$link" >&2
                code=74
            fi
        fi
    done
    ((found == 0)) && echo 'no source file installed'
    exit "$code"
}

cmd_status() {
    local name target link code found
    (($# > 0)) || die 64 'usage: bem status name ...'
    code=0
    for name in "$@"; do
        if [[ ! $name =~ $NAME_RE ]]; then
            printf 'bem: invalid name for program: %s' "$name" >&2
            code=65
            continue
        fi
        found=0
        link="$BEM_LINKS/$name"
        if [[ -L "$link" ]]; then
            found=1
            if target=$(readlink -- "$link"); then
                printf "Program %s: '%q' -> '%q'\n" "$name" "$link" "$target"
            else
                printf 'bem: could not read symlink %q\n' "$link" >&2
                code=74
            fi
        fi
        link="$BEM_SOURCES/$name"
        if [[ -L "$link" ]]; then
            found=1
            if target=$(readlink -- "$link"); then
                printf "Source %s: '%q' -> '%q'\n" "$name" "$link" "$target"
            else
                echo "bem: could not read symlink $link" >&2
                code=74
            fi
        fi
        if ((found == 0)); then
            echo "$name: not found" >&2
            code=66
        fi
    done
    exit "$code"
}

if (($# == 0)); then
	usage
	exit 64
fi

if (( EUID == 0 )) && [[ ${BEM_ALLOW_ROOT:-} != 1 ]]; then
    die 126 'refusing to run as root; set BEM_ALLOW_ROOT=1 if you really want this'
fi
cmd=$1
shift
case $cmd in
    init) init ;;
    install)
        check_installation
        cmd_install "$@"
        ;;
    remove|rm)
        check_installation
        cmd_remove "$@"
        ;;
    source)
        check_installation
        cmd_source "$@"
        ;;
    desource)
        check_installation
        cmd_desource "$@"
        ;;
    list|ls)
        check_installation
        cmd_list "$@"
        ;;
    status)
        check_installation
        cmd_status "$@"
        ;;
    uninstall-bem)
        uninstall_bem
        ;;
    version|--version|-v)
	    echo "bem v$BEM_VERSION"
	    ;;
    help|-h|--help)
    	usage
	    ;;
    *)
	    die 64 'unknown command: %s' "$cmd"
	    ;;
esac
